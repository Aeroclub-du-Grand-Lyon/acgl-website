---
import { getCollection } from "astro:content";
import CtaBanner from "../components/CtaBanner.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import Icon from "../components/Icon.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { url } from "../lib/url";

const allPricing = (await getCollection("pricing")).sort((a, b) => a.data.order - b.data.order);
const membershipPricing = allPricing.filter((p) => p.data.category === "membership");
const trainingPricing = allPricing.filter((p) => p.data.category === "training");

const fleet = (await getCollection("fleet")).sort((a, b) => a.data.order - b.data.order);
const aircraftWithPricing = fleet.filter((a) => !!a.data.normal);
const seenModels = new Set<string>();
const uniqueAircraft = aircraftWithPricing.filter((a) => {
  if (seenModels.has(a.data.key)) return false;
  seenModels.add(a.data.key);
  return true;
});

const pricingDetailsEntries = await getCollection("pricingDetailsSettings");
const pricingDetails = pricingDetailsEntries[0]?.data;

const faqItems = (await getCollection("faq"))
  .filter((f) => f.data.page === "pricing")
  .sort((a, b) => a.data.order - b.data.order)
  .map((f) => ({ q: f.data.question, a: f.data.answer }));

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<MainLayout
  title="Tarifs - Aéroclub du Grand Lyon | Vols avion à Lyon Bron"
  description="Tarifs de l'Aéroclub du Grand Lyon : cotisations, tarifs horaires VFR et IFR par avion, instruction. Association loi 1901, coûts calculés au plus juste."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />

  <PageHero
    title="Tarifs"
    description="Association loi 1901 à but non lucratif - nos coûts sont calculés au plus juste, à la minute moteur tournant."
  >
    {pricingDetails?.updatedOn && (
      <p class="mt-3 flex items-center gap-1.5 text-sm text-white/75">
        <Icon name="clock" size="size-3.5" class="shrink-0" stroke-width="2" />
        Actualisés le {pricingDetails.updatedOn}
      </p>
    )}
  </PageHero>

  <Section bg="surface" border={false}>
      <div class="flex flex-col gap-14">

        {membershipPricing.length > 0 && (
          <div>
            <h2 class="mb-4">Cotisations</h2>
            <p class="mb-6 text-sm text-muted">Dues annuellement à l'inscription ou au renouvellement.</p>
            <dl class="divide-y divide-line rounded-2xl border border-line bg-surface shadow-acgl">
              {membershipPricing.map((item) => (
                <div class="flex flex-wrap items-start justify-between gap-3 px-5 py-4">
                  <div class="flex-1">
                    <dt class="font-medium text-ink">{item.data.key}</dt>
                    {item.data.notes && (
                      <dd class="mt-0.5 text-sm text-muted">{item.data.notes}</dd>
                    )}
                  </div>
                  <dd class="shrink-0 font-display text-lg font-semibold tabular-nums text-brand">
                    {item.data.normal ?? "-"}
                  </dd>
                </div>
              ))}
            </dl>
            {pricingDetails?.membershipNote?.enabled && pricingDetails?.membershipNote?.description && (
              <div class="mt-5 rounded-2xl border border-line bg-light-frost p-4 text-sm leading-relaxed text-muted">
                {pricingDetails.membershipNote.title && (
                  <><strong class="font-semibold text-ink">{pricingDetails.membershipNote.title}</strong>{" - "}</>
                )}
                {pricingDetails.membershipNote.description}
              </div>
            )}
          </div>
        )}

        {uniqueAircraft.length > 0 && (
          <div>
            <h2 class="mb-4">Avions</h2>
            <p class="mb-6 text-sm text-muted">Facturation à la minute, moteur tournant.</p>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {uniqueAircraft.map((item) => {
                const hasIfr = !!item.data.ifrNormal;
                const hasReduction = !!item.data.reduced;
                const isSchool = item.data.schoolAircraft;
                return (
                  <a href={url(`/flotte#${item.id}`)} class="group block h-full no-underline">
                    <Card
                      variant={isSchool ? "surfaceLinkHighlight" : "surfaceLink"}
                      class="flex h-full flex-col"
                    >
                      <div class="mb-4 flex items-start justify-between gap-2">
                        <h3 class="text-sm font-semibold leading-snug text-ink">{item.data.key}</h3>
                        {isSchool && (
                          <Badge variant="brand">Avion école</Badge>
                        )}
                      </div>

                      <div class="grid gap-4" style={hasIfr ? "grid-template-columns: repeat(auto-fit, minmax(100px, 1fr))" : undefined}>
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-label text-muted">VFR</p>
                          <p class="mt-0.5 font-display text-2xl font-bold tabular-nums text-navy leading-none">
                            {item.data.normal ?? "-"}
                          </p>
                          {hasReduction ? (
                            <p class="mt-1 text-sm text-muted">
                              <span class="font-medium text-brand">{item.data.reduced}</span>
                              {" "}réduit
                            </p>
                          ) : (
                            <p class="mt-1 text-sm">&nbsp;</p>
                          )}
                        </div>

                        {hasIfr && (
                          <div class="border-l border-line pl-4">
                            <p class="text-xs font-semibold uppercase tracking-label text-muted">IFR</p>
                            <p class="mt-0.5 font-display text-2xl font-bold tabular-nums text-navy leading-none">
                              {item.data.ifrNormal}
                            </p>
                            {item.data.ifrReduced ? (
                              <p class="mt-1 text-sm text-muted">
                                <span class="font-medium text-brand">{item.data.ifrReduced}</span>
                                {" "}réduit
                              </p>
                            ) : (
                              <p class="mt-1 text-sm">&nbsp;</p>
                            )}
                          </div>
                        )}
                      </div>

                      {item.data.pricingNotes && (
                        <p class="mt-auto pt-4 text-sm leading-relaxed text-muted">
                          {item.data.pricingNotes}
                        </p>
                      )}

                      <p class="mt-auto pt-3 text-xs font-medium text-brand transition-colors duration-[250ms] group-hover:text-navy">
                        Voir la fiche avion →
                      </p>
                    </Card>
                  </a>
                );
              })}
            </div>

            {pricingDetails?.fleetNote?.enabled && pricingDetails?.fleetNote?.description && (
              <div class="mt-5 rounded-2xl border border-line bg-light-frost p-4 text-sm leading-relaxed text-muted">
                {pricingDetails.fleetNote.title && (
                  <><strong class="font-semibold text-ink">{pricingDetails.fleetNote.title}</strong>{" - "}</>
                )}
                {pricingDetails.fleetNote.description}
              </div>
            )}
          </div>
        )}

        {trainingPricing.length > 0 && (
          <div>
            <h2 class="mb-4">Instruction</h2>
            <p class="mb-6 text-sm text-muted">
              Tarif horaire de l'instructeur, en complément du tarif avion.
            </p>
            <div class="grid gap-4 sm:grid-cols-2">
              {trainingPricing.map((item) => (
                <Card>
                  <h3 class="mb-2 text-base">{item.data.key}</h3>
                  <p class="font-display text-2xl font-bold tabular-nums text-brand">
                    {item.data.normal ?? "-"}
                  </p>
                  <p class="mt-1 text-sm text-muted">par heure de vol avec instructeur</p>
                </Card>
              ))}
            </div>
            {pricingDetails?.trainingNote?.enabled && pricingDetails?.trainingNote?.description && (
              <div class="mt-5 rounded-2xl border border-line bg-light-frost p-4 text-sm leading-relaxed text-muted">
                {pricingDetails.trainingNote.title && (
                  <><strong class="font-semibold text-ink">{pricingDetails.trainingNote.title}</strong>{" - "}</>
                )}
                {pricingDetails.trainingNote.description}
              </div>
            )}
          </div>
        )}

        <div>
          <h2 class="mb-8">Tout comprendre sur les tarifs</h2>
          <FaqAccordion items={faqItems} />
        </div>

      </div>
  </Section>

  <CtaBanner
    title="Des questions sur les tarifs ?"
    description="Contactez-nous, nous vous répondrons rapidement."
    primaryHref={url("/contact")}
    primaryLabel="Nous contacter"
  />
</MainLayout>
