---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import CommunityCarousel from "../components/CommunityCarousel.astro";
import CtaBanner from "../components/CtaBanner.astro";
import Icon from "../components/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/Section.astro";
const homeNumbersEntries = await getCollection("homeClubNumbers");
const heroStats = homeNumbersEntries[0]?.data.stats ?? [];

const contactEntries = await getCollection("contactSettings");
const contact = contactEntries[0]?.data;

const fleet = await getCollection("fleet");
const fleetCount = fleet.length;

const instructors = await getCollection("instructors");
const instructorCount = instructors.length;

const pathCards: { href: string; icon: string; label: string; title: string; desc: string; cta: string }[] = [
  {
    href: "/vol-decouverte",
    icon: "compass",
    label: "Découvrir",
    title: "Vols découverte",
    desc: "S'initier au plaisir de voler accompagné d'un de nos instructeurs.",
    cta: "Offrir ou s'offrir un vol",
  },
  {
    href: "/ecole-de-pilotage",
    icon: "book-open",
    label: "Apprendre",
    title: "École de pilotage",
    desc: `Formation PPL(A) ou LAPL(A) avec nos instructeurs, du premier vol à la licence.`,
    cta: "Devenir pilote",
  },
  {
    href: "/deja-pilote",
    icon: "plane",
    label: "Voler",
    title: "Déjà pilote",
    desc: "Rejoignez notre communauté de pilotes et volez sur notre flotte diversifiée.",
    cta: "Rejoindre le club",
  },
  {
    href: "/progresser",
    icon: "trending-up",
    label: "Progresser",
    title: "Perfectionnements",
    desc: "Vol de nuit, train rentrant, IFR : enrichissez votre licence avec des qualifications avancées.",
    cta: "Se perfectionner",
  },
];
---

<MainLayout
  title="Aéroclub du Grand Lyon | Apprendre à piloter et voler à Lyon Bron"
  description="Apprenez à piloter ou volez avec votre licence depuis l'aéroport de Lyon Bron. Des instructeurs passionnés, une flotte de 8 avions et une vraie ambiance club - ACGL, agréé DGAC."
>
  <section
    class="relative isolate flex flex-col lg:overflow-hidden min-h-[80svh] pb-6 pt-[calc(var(--spacing-header-h)+2.5rem)] md:pb-8 md:pt-[calc(var(--spacing-header-h)+3.5rem)] lg:min-h-[80vh] lg:pb-20"
    aria-labelledby="hero-heading"
  >
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <Image
        src="/images/hero.jpg"
        alt="Avion de l'Aéroclub du Grand Lyon prêt au décollage sur l'aéroport de Lyon Bron"
        class="h-full w-full object-cover object-center"
        width=1920
        height=1080
        loading="eager"
        fetchpriority="high"
        decoding="async"
        quality={80}
      />
    </div>
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-navy/80 via-navy/40 to-navy/25" aria-hidden="true" />

    <div class="container relative z-[1] flex flex-col flex-1 lg:justify-center lg:gap-15">

      <!-- Text block + mobile card strip — centered as a group on mobile, transparent on desktop -->
      <div class="flex-1 flex flex-col justify-center gap-8 lg:contents">

        <div class="flex flex-col items-center justify-center text-center lg:flex-row lg:items-center lg:text-left lg:gap-10">
          <Image
            src="/logo-mini.svg"
            alt="Logo de l'Aéroclub du Grand Lyon"
            width="96"
            height="96"
            class="mb-6 size-32 drop-shadow-md lg:mb-0 lg:size-28 lg:shrink-0"
            loading="eager"
          />
          <div>
            <h1
              id="hero-heading"
              class="mb-4 font-display text-[clamp(1.75rem,4.5vw,2.75rem)] font-semibold tracking-tight text-white md:mb-5"
            >
              Voler à Lyon Bron, <br class="hidden sm:block" /> c'est ici que ça commence !
            </h1>
            <p class="mx-auto text-sm leading-relaxed text-white/80 md:text-base lg:mx-0">
              Apprenez à piloter ou volez avec votre licence à l'Aéroclub du Grand Lyon. Découvrez nos parcours adaptés à vos envies.
            </p>
          </div>
        </div>

        <div class="lg:hidden">
          <div
            id="hero-cards-scroll"
            class="overflow-x-auto snap-x snap-mandatory scrollbar-none [scroll-padding-inline:1.5rem]"
          >
            <div class="flex gap-4 px-6 pr-12 pb-4">
              {pathCards.map(({ href, icon, label, title, desc, cta }) => (
                <a
                  href={href}
                  class="group snap-center shrink-0 w-[82vw] sm:w-[50vw] flex flex-col no-underline rounded-2xl p-6 border-2 border-transparent bg-white shadow-acgl-lg transition-all duration-[250ms] active:scale-[0.98]"
                >
                  <div class="flex items-center gap-3 mb-3">
                    <div class="flex size-10 items-center justify-center rounded-full bg-brand/10 text-brand" aria-hidden="true">
                      <Icon name={icon} size="size-5" />
                    </div>
                    <h3 class="text-xs font-bold uppercase tracking-label text-brand">{label}</h3>
                  </div>
                  <h4 class="mb-2 text-lg font-bold text-navy">{title}</h4>
                  <p class="mb-6 flex-1 text-sm leading-relaxed text-muted">{desc}</p>
                  <div class="mt-auto flex items-center justify-center gap-2 rounded-lg bg-brand px-4 py-3 text-sm font-bold text-white shadow-md transition-colors group-hover:bg-navy">
                    {cta}
                    <Icon name="arrow-right" size="size-4" class="transition-transform group-hover:translate-x-1" />
                  </div>
                </a>
              ))}
            </div>
          </div>
          <div class="mt-2 flex justify-center gap-1.5" aria-hidden="true">
            {pathCards.map((_, i) => (
              <div class:list={["hero-dot size-1.5 rounded-full transition-colors duration-300", i === 0 ? "bg-white" : "bg-white/30"]} data-index={i} />
            ))}
          </div>
        </div>

        <script is:inline>
          (function() {
            const scrollContainer = document.getElementById('hero-cards-scroll');
            const dots = document.querySelectorAll('.hero-dot');
            if (!scrollContainer || !dots.length) return;

            scrollContainer.addEventListener('scroll', () => {
              const scrollLeft = scrollContainer.scrollLeft;
              const width = scrollContainer.offsetWidth;
              const index = Math.round(scrollLeft / (width * 0.8)); // 0.8 matches the 82vw approx

              dots.forEach((dot, i) => {
                if (i === index) {
                  dot.classList.add('bg-white');
                  dot.classList.remove('bg-white/30');
                } else {
                  dot.classList.remove('bg-white');
                  dot.classList.add('bg-white/30');
                }
              });
            }, { passive: true });
          })();
        </script>

      </div>

      <div class="hidden lg:block">
        <h2 id="path-cards-heading" class="sr-only">Votre projet à l'ACGL</h2>
        <div class="grid gap-4 lg:grid-cols-4">
          {pathCards.map(({ href, icon, label, title, desc, cta }) => (
            <Card as="a" href={href} variant="surfaceLink" class="h-full bg-page">
              <div class="flex items-center gap-3 mb-4">
                <div class="card-surface-icon" aria-hidden="true">
                  <Icon name={icon} size="size-5" />
                </div>
                <h3 class="text-base font-bold uppercase tracking-label text-brand">{title}</h3>
              </div>
              <p class="mb-4 flex-1 text-sm leading-relaxed text-muted">{desc}</p>
              <span class="card-surface-cta">
                {cta}
                <Icon name="arrow-right" size="size-4" class="card-surface-cta-arrow" />
              </span>
            </Card>
          ))}
        </div>
      </div>

      {heroStats.length > 0 && (
        <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 w-fit mx-auto mt-8 pb-2 lg:border-t lg:border-white/20 lg:pt-7 lg:pb-0" role="group" aria-label="Chiffres clés du club">
      <ul class="flex flex-wrap justify-center gap-8 p-0 list-none">
          {heroStats.map((item) => (
        <li class="flex flex-col items-center gap-0.5">
              <span class="font-display text-xl font-semibold tabular-nums leading-none text-white">{item.value}</span>
              <span class="text-xs font-medium uppercase tracking-label text-white/70">{item.label}</span>
        </li>
          ))}
      </ul>
          <span class="hidden h-5 w-px bg-white/20 sm:block" aria-hidden="true"></span>
          <span class="hidden items-center gap-1.5 text-sm text-white/70 sm:flex">
            <Icon name="users" size="size-3.5" class="shrink-0 text-sky" />
            Affilié à la Fédération Française Aéronautique
          </span>
        </div>
      )}

    </div>
  </section>

  <Section bg="surface" class="py-section-y md:py-section-y-lg border-none!">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <header class="mb-10 text-left md:mb-12">
          <h2 class="text-3xl md:text-4xl">Pourquoi choisir l'ACGL ?</h2>
          <p class="mt-4 text-lg text-muted">
            Un club ouvert à tous, où la passion de l'aviation se transmet dans une ambiance conviviale et sécurisée.
          </p>
        </header>
        <ul class="grid gap-6 sm:grid-cols-2">
          <Card as="li" size="md" class="bg-page">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
                <Icon name="plane" size="size-6" />
              </div>
              <h3 class="text-base font-bold">Flotte diversifiée</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted">
              {fleetCount} avions pour toutes vos envies : formation, voyage ou vol aux instruments.
            </p>
          </Card>
          <Card as="li" size="md" class="bg-page">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
                <Icon name="graduation" size="size-6" />
              </div>
              <h3 class="text-base font-bold">Instructeurs</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted">
              {instructorCount} instructeurs passionnés à votre écoute en semaine et le week-end.
            </p>
          </Card>
          <Card as="li" size="md" class="bg-page">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
                <Icon name="euro" size="size-6" />
              </div>
              <h3 class="text-base font-bold">Tarifs associatifs</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted">
              Structure 1901 à but non lucratif : le vol au prix le plus juste, carburant inclus.
            </p>
          </Card>
          <Card as="li" size="md" class="bg-page">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
                <Icon name="shield" size="size-6" />
              </div>
              <h3 class="text-base font-bold">Culture sécurité</h3>
            </div>
            <p class="text-sm leading-relaxed text-muted">
              La sécurité est notre priorité absolue, cultivée par le partage d'expérience.
            </p>
          </Card>
        </ul>
      </div>

      <div class="relative lg:pl-10">
        <CommunityCarousel
          images={[
            { src: "/images/hero.jpg", alt: "Ambiance conviviale à l'aéroclub" },
            { src: "/images/fleet/cessna-172/photo.jpg", alt: "Un avion de la flotte prêt pour le départ" },
            { src: "/images/fleet/piper-pa28-archer/photo.jpg", alt: "Piper Archer sur le parking de Bron" },
          ]}
        />
        <div class="absolute -bottom-6 -right-6 -z-10 hidden size-64 rounded-full bg-brand/5 lg:block"></div>
        <div class="absolute -left-6 -top-6 -z-10 hidden size-32 rounded-full bg-sky/10 lg:block"></div>
      </div>
    </div>
  </Section>


  <CtaBanner
    bg="surface"
    title="Nous rencontrer"
    description={contact?.permanence
      ? `Une permanence club a lieu ${contact.permanence}`
      : "Contactez-nous pour organiser une rencontre dans nos locaux."}
    primaryHref="/contact"
    primaryLabel="Voir les infos pratiques"
  >
  </CtaBanner>
</MainLayout>

