---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Card from "../components/Card.astro";
import CtaBanner from "../components/CtaBanner.astro";
import Icon from "../components/Icon.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Section from "../components/Section.astro";
const surfaceLinkCardLeadIcon =
  "flex size-10 items-center justify-center rounded-full bg-brand/10 text-brand transition-[transform,background-color,color] duration-[250ms] group-hover:scale-110 group-hover:bg-brand group-hover:text-white";

const surfaceLinkCardCta =
  "mt-auto flex items-center gap-1.5 text-sm font-semibold text-brand transition-colors duration-[250ms] group-hover:text-navy";

const homeNumbersEntries = await getCollection("homeClubNumbers");
const heroStats = homeNumbersEntries[0]?.data.stats ?? [];

const contactEntries = await getCollection("contactSettings");
const contact = contactEntries[0]?.data;

const fleet = await getCollection("fleet");
const fleetCount = fleet.length;

const instructors = await getCollection("instructors");
const instructorCount = instructors.length;

const pathCards: { href: string; icon: string; label: string; title: string; desc: string; cta: string }[] = [
  {
    href: "/vol-decouverte",
    icon: "compass",
    label: "Découvrir",
    title: "Vols découverte",
    desc: "S'initier au plaisir de voler accompagné d'un de nos instructeurs.",
    cta: "Offrir ou s'offrir un vol",
  },
  {
    href: "/ecole-de-pilotage",
    icon: "book-open",
    label: "Apprendre",
    title: "École de pilotage",
    desc: `Formation PPL(A) ou LAPL(A) avec nos instructeurs, du premier vol à la licence.`,
    cta: "Devenir pilote",
  },
  {
    href: "/deja-pilote",
    icon: "plane",
    label: "Voler",
    title: "Déjà pilote",
    desc: "Rejoignez notre communauté de pilotes et volez sur notre flotte diversifiée.",
    cta: "Rejoindre le club",
  },
  {
    href: "/progresser",
    icon: "trending-up",
    label: "Progresser",
    title: "Perfectionnements",
    desc: "Vol de nuit, train rentrant, IFR : enrichissez votre licence avec des qualifications avancées.",
    cta: "Se perfectionner",
  },
];
---

<MainLayout
  title="Aéroclub du Grand Lyon | Apprendre à piloter et voler à Lyon Bron"
  description="Apprenez à piloter ou volez avec votre licence depuis l'aéroport de Lyon Bron. Des instructeurs passionnés, une flotte de 8 avions et une vraie ambiance club - ACGL, agréé DGAC."
>
  <section
    class="relative isolate overflow-hidden min-h-dvh flex flex-col pt-[var(--spacing-header-h)] pb-10"
    aria-labelledby="hero-heading"
  >
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <Image
        src="/images/hero.jpg"
        alt=""
        class="h-full w-full object-cover object-center"
        width=1920
        height=1080
        loading="eager"
        fetchpriority="high"
        decoding="async"
        quality={80}
      />
    </div>
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-navy/50 via-navy/10 to-navy/50" aria-hidden="true" />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-navy/50 via-navy/25 to-navy/65" aria-hidden="true" />

    <div class="container relative z-[1] flex flex-1 flex-col items-center justify-center gap-8 py-10 text-center md:gap-10">

      <div>
        <h1
          id="hero-heading"
          class="mb-3 font-display text-[clamp(1.75rem,4.5vw,2.75rem)] font-semibold tracking-tight text-white md:mb-4"
        >
          Voler, <span class="text-sky">c'est ici</span> que ça commence !
        </h1>
        <p class="text-sm leading-relaxed text-white/80 md:text-base">
          Apprenez à piloter ou volez avec votre licence depuis Lyon Bron.
        </p>
      </div>

      <div class="rounded-full shadow-[0_8px_64px_rgba(0,0,0,0.45)] backdrop-blur-sm ring-1 ring-navy/40">
        <img
          src="/logo.svg"
          alt="Logo Aéroclub du Grand Lyon"
          class="w-28 sm:w-36 md:w-48 lg:w-60 xl:w-72"
        />
      </div>

      {heroStats.length > 0 && (
        <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 border-t border-white/15 pt-6" role="group" aria-label="Chiffres clés du club">
          <div class="flex flex-col gap-5 sm:flex-row">
            {heroStats.map((item) => (
              <span class="flex flex-col items-center gap-0.5">
                <span class="font-display text-xl font-semibold tabular-nums leading-none text-white">{item.value}</span>
                <span class="text-xs font-medium uppercase tracking-label text-white/70">{item.label}</span>
              </span>
            ))}
          </div>
          <span class="hidden h-5 w-px bg-white/15 sm:block" aria-hidden="true"></span>
          <span class="hidden items-center gap-1.5 text-sm text-white/70 sm:flex">
            <Icon name="users" size="size-3.5" class="shrink-0 text-sky" />
            Affilié à la Fédération Française Aéronautique
          </span>
        </div>
      )}
    </div>

    <a
      href="#paths"
      class="relative z-[1] mx-auto flex flex-col items-center gap-2 text-white/50 transition-colors duration-[250ms] hover:text-white/80"
      aria-label="Découvrir les parcours"
    >
      <span class="text-xs font-medium uppercase tracking-label">Découvrez votre parcours</span>
      <Icon name="chevron-down" size="size-5" class="animate-bounce" />
    </a>
  </section>

  <section
    id="paths"
    aria-labelledby="paths-heading"
    class="relative z-10 -mt-10 rounded-t-3xl bg-page py-section-y max-md:py-section-y-mobile scroll-mt-header-h border-b border-line"
  >
    <div class="container">
      <header class="mx-auto mb-10 text-center md:mb-12">
        <h2 id="paths-heading">Quel est votre projet ?</h2>
        <p class="mt-3 text-muted">Que vous rêviez de voler ou que vous ayez déjà votre licence.</p>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 md:gap-5">
        {pathCards.map(({ href, icon, label, title, desc, cta }) => (
          <Card as="a" href={href} variant="surfaceLink" class="h-full bg-page">
            <div class="flex items-center gap-3 mb-4">
              <div class={surfaceLinkCardLeadIcon} aria-hidden="true">
                <Icon name={icon} size="size-5" />
              </div>
              <h3 class="text-base font-bold uppercase tracking-label text-brand">{label}</h3>
            </div>
            <p class="hidden mb-2 text-sm text-navy font-semibold transition-colors duration-[250ms] group-hover:text-brand">{title}</p>
            <p class="mb-4 flex-1 text-sm leading-relaxed text-muted">{desc}</p>
            <span class={surfaceLinkCardCta}>
              {cta}
              <Icon name="arrow-right" size="size-4" class="transition-transform duration-[250ms] group-hover:translate-x-1" />
            </span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <Section bg="surface" class="py-section-y md:py-section-y-lg">
    <header class="mx-auto mb-10 text-center md:mb-12">
      <h2>Pourquoi choisir l'ACGL ?</h2>
      <p class="mt-3 text-muted">Un club ouvert à tous, que vous soyez novice ou un pilote confirmé.</p>
    </header>
    <div class="grid gap-6 sm:grid-cols-2">
      <Card size="lg" class="bg-page">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
            <Icon name="plane" size="size-6" />
          </div>
          <h3>Flotte diversifiée</h3>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          Une flotte de {fleetCount} avions permettant de répondre à toutes vos envies. Formation, balade, voyage ou encore vol aux instruments.
        </p>
      </Card>
      <Card size="lg" class="bg-page">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
            <Icon name="graduation" size="size-6" />
          </div>
          <h3>Instructeurs qualifiés</h3>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          {instructorCount} instructeurs disponibles en semaine ou le week-end pour vous accompagner que vous soyez élèves ou déjà pilote.
        </p>
      </Card>
      <Card size="lg" class="bg-page">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
            <Icon name="euro" size="size-6" />
          </div>
          <h3>Tarifs associatifs</h3>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          Association loi 1901 à but non lucratif : coûts calculés au plus juste. Facturation carburant inclus, à la minute, moteur tournant.
        </p>
      </Card>
      <Card size="lg" class="bg-page">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex size-10 items-center justify-center rounded-lg bg-light-frost text-brand" aria-hidden="true">
            <Icon name="shield" size="size-6" />
          </div>
          <h3>Sécurité & culture juste</h3>
        </div>
        <p class="mt-2 text-sm leading-relaxed text-muted">
          Signalement libre, retours d'expérience et accompagnement bienveillant : la sécurité est un état d'esprit partagé par tous.
        </p>
      </Card>
    </div>
  </Section>

  <CtaBanner
    bg="page"
    title="Nous rencontrer"
    description={contact?.permanence
      ? `Une permanence club à lieu ${contact.permanence}`
      : "Contactez nous pour organiser une rencontre dans nos locaux."}
    primaryHref="/contact"
    primaryLabel="Voir les infos pratiques"
  >
  </CtaBanner>
</MainLayout>
