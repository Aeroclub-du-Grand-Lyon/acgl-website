---
import { getCollection } from "astro:content";
import ButtonLink from "../components/ButtonLink.astro";
import Card from "../components/Card.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import Badge from "../components/Badge.astro";
import CtaBanner from "../components/CtaBanner.astro";
import MainLayout from "../layouts/MainLayout.astro";


const allRatings = (await getCollection("ratings")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<MainLayout
  title="Perfectionnements & qualifications - Aéroclub du Grand Lyon | Lyon Bron"
  description="Vol de nuit, IFR CB-IR, vol en montagne : enrichissez votre licence avec des qualifications avancées à l'Aéroclub du Grand Lyon, au départ de Lyon Bron."
>
  <PageHero
    title="Enrichir ses compétences"
    description="Titulaire d'une licence, enrichissez votre carnet de vol avec des qualifications avancées encadrées par nos instructeurs."
  />

  {allRatings.length > 0 && (
    <Section id="qualifications" labelledby="qualifications-heading" bg="surface">
      <header class="mb-10">
        <h2 id="qualifications-heading">Perfectionnements &amp; qualifications</h2>
        <p class="mt-3 text-muted">
          Chaque qualification ouvre de nouvelles possibilités de vol. Nos instructeurs vous accompagnent tout au long de la formation.
        </p>
      </header>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {allRatings.map((item) => (
          <Card
            class:list={[
              "bg-page",
              !item.data.available && "border-dashed opacity-60",
            ]}
          >
            <div class="flex items-start justify-between gap-3">
              <h3 class="m-0 text-base">{item.data.title}</h3>
              {!item.data.available && (
                <Badge variant="outline">Sur demande</Badge>
              )}
            </div>
            {item.data.conditions && (
              <p class="mt-3 text-sm text-muted">
                <strong class="font-semibold text-ink">Prérequis :</strong>{" "}
                {item.data.conditions}
              </p>
            )}
            {item.data.description && (
              <p class="mt-2 text-sm leading-relaxed text-muted">{item.data.description}</p>
            )}
          </Card>
        ))}
      </div>
    </Section>
  )}

  <Section bg="page">
    <header class="mb-10">
      <h2>Vous n'avez pas encore votre licence ?</h2>
      <p class="mt-3 text-muted">
        Notre école de pilotage vous accompagne du premier vol à l'obtention de votre PPL(A) ou LAPL(A).
      </p>
    </header>
    <div class="flex flex-wrap gap-3">
      <ButtonLink href="/ecole-de-pilotage" variant="blue">Découvrir la formation</ButtonLink>
      <ButtonLink href="/vol-decouverte" variant="outline-dark">Commencer par un vol découverte</ButtonLink>
    </div>
  </Section>

  <CtaBanner
    title="Prêt à aller plus loin ?"
    description="Contactez-nous pour discuter de votre projet de qualification ou venez rencontrer nos instructeurs."
    primaryHref="/contact"
    primaryLabel="Nous contacter"
    secondaryHref="/tarifs"
    secondaryLabel="Voir les tarifs"
  >
  </CtaBanner>
</MainLayout>
