---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "outline" | "blue" | "outline-dark";

interface Props extends HTMLAttributes<"a"> {
  variant?: Variant;
}

const {
  variant = "blue",
  class: className,
  ...rest
} = Astro.props;

const base =
  "inline-flex cursor-pointer items-center justify-center gap-2 rounded-lg border-none px-6 py-3 font-display text-sm font-semibold no-underline transition-[box-shadow,background,color,border-color] duration-[250ms] ease-in-out";

const variants: Record<Variant, string> = {
  primary:
    "bg-white text-navy shadow-[0_2px_12px_rgb(0_0_0/0.15)] hover:bg-light-frost hover:text-brand hover:shadow-[0_8px_28px_rgb(0_0_0/0.14)]",
  outline:
    "border-[1.5px] border-solid border-white/35 bg-transparent text-white hover:border-white/60 hover:bg-white/10 hover:text-white hover:shadow-[0_6px_20px_rgb(0_0_0/0.12)]",
  blue:
    "bg-brand text-white shadow-[0_2px_12px_rgb(4_103_179/0.3)] hover:bg-navy hover:text-white hover:shadow-[0_8px_28px_rgb(4_32_90/0.22)]",
  "outline-dark":
    "border-[1.5px] border-solid border-line bg-transparent text-navy shadow-none hover:border-brand hover:bg-light-frost hover:text-brand hover:shadow-[0_6px_22px_rgb(4_32_90/0.1)]",
};
---

<a class:list={[base, variants[variant], className]} {...rest}>
  <slot />
</a>
