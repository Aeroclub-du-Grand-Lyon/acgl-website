const isFilled = name === "facebook" || name === "plane";
const strokeProps = isFilled ? {} : { stroke: "currentColor", "stroke-width": "1.75", "stroke-linecap": "round", "stroke-linejoin": "round" };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill={isFilled ? "currentColor" : "none"}
  {...strokeProps}
  class:list={[size, className]}
  aria-hidden="true"
  {...rest}
  set:html={icons[name]}
/>
