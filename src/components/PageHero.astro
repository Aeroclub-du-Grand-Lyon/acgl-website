---
import Badge from "./Badge.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<div class="border-b border-line bg-gradient-to-br from-navy via-navy to-brand pb-12 pt-[calc(var(--spacing-header-h)+3rem)] text-white md:pb-16">
  <div class="container">
    <h1 class="text-white">{title}</h1>
    {description && (
      <p class="mt-3 text-lg text-white/85">{description}</p>
    )}
    <slot />
  </div>
</div>
